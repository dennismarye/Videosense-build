pipeline {
    agent any

    environment {
        AWS_ACCESS_KEY_ID     = credentials('aws-access-key-id')
        AWS_SECRET_ACCESS_KEY = credentials('aws-secret-access-key')
        AWS_REGION           = credentials('aws-region')
        AWS_ACCOUNT_ID       = credentials('aws-account-id')
        EC2_SSH_PRIVATE_KEY  = credentials('prod-ssh-private-key')
        EC2_USER             = credentials('ec2-user')
        EC2_HOST             = credentials('prod-ec2-host')
        SONAR_KEY            = credentials('sonar-pat')
        SONAR_HOST_URL       = credentials('sonar-host-url')
    }

    stages {
        stage('Checkout/Clone Repository') {
            steps {
                checkout scm
            }
        }

        stage('Set up Python Build, Lint and Tests') {
            steps {
                sh '''
                # Remove previous venv if it exists
                rm -rf venv

                # Create a new virtual environment
                python3 -m venv venv
                . venv/bin/activate

                #Install Python dependencies
                python -m pip install --upgrade pip
                pip install -r requirements.txt
                pip install pytest httpx requests
                pip install flake8 black mypy

                # Lint with flake8
                flake8 . --count --select=E9,F63,F7,F82 --show-source --statistics
                flake8 . --count --exit-zero --max-complexity=10 --max-line-length=127 --statistics

                # Check formatting with Black
                black --check .

                #Type checking with mypy
                #mypy src/

                #Running unit test with pytest
                #pytest tests/
                '''
            }
        }

        // stage('SonarQube Analysis') {
        //     steps {
        //         script {
        //             def scannerHome = tool 'SonarScanner'
        //             withSonarQubeEnv('Sonarqube') {
        //                 sh """
        //                     ${scannerHome}/bin/sonar-scanner \
        //                     -Dsonar.projectKey=prod-video-classification \
        //                     -Dsonar.sources=. \
        //                     -Dsonar.host.url=${SONAR_HOST_URL} \
        //                     -Dsonar.login=${SONAR_KEY}
        //                 """
        //             }
        //         }
        //     }
        // }

        // stage("Quality Gate") {
        //     steps {
        //         timeout(time: 1, unit: 'HOURS') {
        //             script {
        //                 def qg = waitForQualityGate()
        //                 if (qg.status != 'OK') {
        //                     error("Pipeline aborted due to quality gate failure: ${qg.status}")
        //                 }
        //             }
        //         }
        //     }
        // }

        stage('Build Docker Image') {
            steps {
                script {
                    sh "docker build -t prod-video-classification ."
                }
            }
        }

        stage('Push to ECR') {
            steps {
                script {
                    def versionTag = "1.0.${BUILD_NUMBER}"
                    def ecrRepo = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/prod-video-classification"

                    sh """
                        # Login to ECR
                        aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com

                        # Tag with both version number and latest
                        docker tag prod-video-classification:latest ${ecrRepo}:${versionTag}
                        docker tag prod-video-classification:latest ${ecrRepo}:latest

                        # Push both tags
                        docker push ${ecrRepo}:${versionTag}
                        docker push ${ecrRepo}:latest

                        # Clean up local images
                        docker rmi prod-video-classification:latest ${ecrRepo}:${versionTag} ${ecrRepo}:latest

                        # Output version information for logging
                        echo "Successfully pushed version ${versionTag} and latest tags to ECR"
                    """
                }
            }
        }

        stage('Deploy to EC2') {
            steps {
                script {
                    sh 'cp $EC2_SSH_PRIVATE_KEY ec2_key.pem'
                    sh 'chmod 400 ec2_key.pem'

                    sh """
                        ssh -T -o StrictHostKeyChecking=no -i ec2_key.pem ${EC2_USER}@${EC2_HOST} << EOSSH
                            cd /home/ubuntu/prod-circo/prod-video-classification
                            sudo ./deploy.sh
EOSSH
                    """
                    // Clean up key file
                    sh 'rm -f ec2_key.pem'
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
    }
}
